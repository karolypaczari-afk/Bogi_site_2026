---
layout: "base.njk"
title: "Blog | Process Optimization & Transformation Case Studies by Bogi Horvath"
description: "Real-world case studies and insights into process optimization, digital transformation, SAP S/4HANA, PEGA migrations, Lean Six Sigma, and strategic leadership by Bogi Horvath."
canonical: "https://bogihorvath.com/blog/"
permalink: "/blog/index.html"
pageType: "blog"
ogImageAlt: "Bogi Horvath blog — process optimization and digital transformation insights"
keywords: "process optimization blog, digital transformation case studies, Lean Six Sigma examples, SAP PEGA migration case study, business analysis insights"
breadcrumbs:
    - { name: "Home", url: "https://bogihorvath.com/" }
    - { name: "Blog", url: "https://bogihorvath.com/blog/" }
---

<section class="blog">
    <div class="container">
        <div class="section-header reveal">
            <span class="eyebrow">Insights &amp; Case Studies</span>
            <h1 class="section-title">Thoughts from the <em>Field</em></h1>
            <p class="section-lead">Real-world case studies and insights into process optimization, digital transformation, and strategic leadership.</p>
        </div>

        <div class="blog__grid" data-stagger>
            {% for post in posts %}
            <article class="blog-card reveal">
                <a href="/blog/{{ post.id }}/" class="blog-card__cover" aria-label="Read {{ post.title }}">
                    <img src="{{ post.cover }}" alt="{{ post.title }}" width="800" height="450" loading="lazy">
                </a>
                <div class="blog-card__body">
                    <div class="blog-card__meta">
                        <span class="blog-card__category">{{ post.category }}</span>
                        <span class="blog-card__date">{{ post | readingTime }}</span>
                    </div>
                    <h2 class="blog-card__title">
                        <a href="/blog/{{ post.id }}/" style="color:inherit;text-decoration:none">{{ post.title }}</a>
                    </h2>
                    <p class="blog-card__summary">{{ post.summary }}</p>
                    <a href="/blog/{{ post.id }}/" class="blog-card__link">
                        Read Full Article <i class="fas fa-chevron-right" aria-hidden="true"></i>
                    </a>
                </div>
            </article>
            {% endfor %}
        </div>
    </div>
</section>
