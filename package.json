{
  "name": "bogi-horvath-site",
  "version": "1.0.0",
  "private": true,
  "description": "Static site for bogihorvath.com - Senior Business Analyst & Digital Transformation Lead portfolio",
  "scripts": {
    "eleventy": "npx @11ty/eleventy",
    "dev": "npx @11ty/eleventy --watch",
    "biome:check": "biome check biome.json .htmlvalidate.json .stylelintrc.json package.json playwright.config.js",
    "biome:format": "biome format --write biome.json .htmlvalidate.json .stylelintrc.json package.json playwright.config.js",
    "htmlvalidate:check": "html-validate index.html about/index.html privacy/index.html cookies/index.html recruiters/index.html blog/index.html \"blog/*/index.html\" 404.html",
    "lint:css": "stylelint \"css/**/*.src.css\"",
    "check": "npm run biome:check && npm run htmlvalidate:check && npm run lint:css",
    "test": "npx playwright test",
    "test:fast": "node _dev/test-fast.js",
    "test:smoke": "npx playwright test --grep @smoke",
    "test:a11y": "npx playwright test --grep @a11y",
    "test:seo": "npx playwright test --grep @seo",
    "test:responsive": "npx playwright test --grep @responsive",
    "test:visual": "npx playwright test --grep @visual",
    "test:visual:update": "npx playwright test --grep @visual --update-snapshots",
    "test:full": "npm run build && npx playwright test",
    "report": "npx playwright show-report",
    "build": "node _dev/build.js && npx @11ty/eleventy",
    "build:css": "node _dev/build.js --type css",
    "build:js": "node _dev/build.js --type js",
    "watch": "chokidar \"css/*.src.css\" \"js/*.src.js\" -c \"node _dev/build.js --file {path}\"",
    "optimize:images": "node _dev/scripts/optimize-images.js",
    "optimize:images:dry": "node _dev/scripts/optimize-images.js --dry-run",
    "serve": "npx http-server . -p 8080 -c-1"
  },
  "devDependencies": {
    "@11ty/eleventy": "^2.0.1",
    "@axe-core/playwright": "^4.10.0",
    "@biomejs/biome": "^2.4.11",
    "@playwright/test": "^1.50.0",
    "chokidar-cli": "^3.0.0",
    "clean-css-cli": "^4.3.0",
    "html-validate": "^10.11.3",
    "http-server": "^14.1.1",
    "sharp": "^0.34.5",
    "stylelint": "^17.6.0",
    "stylelint-config-standard": "^40.0.0",
    "subset-font": "^2.5.0",
    "terser": "^5.37.0"
  }
}
