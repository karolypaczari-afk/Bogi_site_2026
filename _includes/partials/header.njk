    <header class="site-header">
        <div class="container site-header__inner">
            <a class="logo" href="/" aria-label="{{ site.name }} — home">
                Bogi<span>Horvath</span>
            </a>

            <nav class="nav" aria-label="Main navigation">
                {% for item in nav.main %}
                <a class="nav__link" href="{{ item.href }}">{{ item.label }}</a>
                {% endfor %}
                <a class="nav__cta" href="{{ nav.cta.href }}">{{ nav.cta.label }}</a>
            </nav>

            <button class="nav-toggle" type="button" data-nav-toggle aria-controls="mobile-nav" aria-expanded="false" aria-label="Open menu">
                <i class="fas fa-bars" aria-hidden="true"></i>
            </button>
        </div>
    </header>

    <div class="mobile-nav" id="mobile-nav" data-mobile-nav aria-label="Mobile menu" role="dialog" aria-modal="true">
        <div class="mobile-nav__header">
            <div class="logo">Bogi<span>Horvath</span></div>
            <button class="mobile-nav__close" type="button" data-nav-close aria-label="Close menu">
                <i class="fas fa-times" aria-hidden="true"></i>
            </button>
        </div>
        <div class="mobile-nav__body">
            <div class="mobile-nav__links">
                {% for item in nav.main %}
                <a class="mobile-nav__link" href="{{ item.href }}">{{ item.label }}</a>
                {% endfor %}
            </div>
            <div class="mobile-nav__ctas">
                <a class="mobile-nav__cta mobile-nav__cta--primary" href="/#contact">
                    <i class="fas fa-envelope" aria-hidden="true"></i>
                    Contact Me
                </a>
                <a class="mobile-nav__cta mobile-nav__cta--secondary" href="{{ site.contact.resume }}" target="_blank" rel="noopener noreferrer">
                    <i class="far fa-file-alt" aria-hidden="true"></i>
                    Download CV
                </a>
            </div>
            <div class="mobile-nav__contact">
                <a href="{{ site.contact.linkedin }}" target="_blank" rel="noopener noreferrer">
                    <i class="fab fa-linkedin" aria-hidden="true"></i> Connect on LinkedIn
                </a>
                <a href="{{ site.contact.emailHref }}">
                    <i class="far fa-envelope" aria-hidden="true"></i> {{ site.contact.email }}
                </a>
            </div>
        </div>
    </div>
