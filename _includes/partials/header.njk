    <header class="site-header">
        <div class="container site-header__inner">
            <a class="logo" href="/">
                Bogi<span>Horvath</span>
            </a>

            <nav class="nav" aria-label="Main navigation">
                <ul class="nav__group nav__group--pages">
                    {% for item in nav.pages %}
                    {% set isActive = (page.url == item.href) or (item.href != '/' and page.url and page.url.startsWith(item.href)) %}
                    <li>
                        <a class="nav__link{% if isActive %} is-active{% endif %}" href="{{ item.href }}"{% if isActive %} aria-current="page"{% endif %}>{{ item.label }}</a>
                    </li>
                    {% endfor %}
                </ul>

                {% if nav.sections and nav.sections.length %}
                <span class="nav__divider" aria-hidden="true"></span>
                <ul class="nav__group nav__group--sections">
                    {% for item in nav.sections %}
                    <li>
                        <a class="nav__link nav__link--section" href="{{ item.href }}">
                            <span class="nav__hash" aria-hidden="true">#</span>{{ item.label }}
                        </a>
                    </li>
                    {% endfor %}
                </ul>
                {% endif %}

                <a class="nav__cta"
                   href="{{ nav.cta.href }}"
                   {% if nav.cta.href | first == '/' and '.pdf' in nav.cta.href %}target="_blank" rel="noopener noreferrer"{% endif %}
                   data-cta-location="header_nav">
                    <i class="far fa-file-pdf" aria-hidden="true"></i>
                    <span class="nav__cta-text">
                        <span class="nav__cta-label">{{ nav.cta.label }}</span>
                        {% if nav.cta.sub %}<span class="nav__cta-sub">{{ nav.cta.sub }}</span>{% endif %}
                    </span>
                </a>
            </nav>

            <button class="nav-toggle" type="button" data-nav-toggle aria-controls="mobile-nav" aria-expanded="false" aria-label="Open menu">
                <i class="fas fa-bars" aria-hidden="true"></i>
            </button>
        </div>
    </header>

    <div class="mobile-nav" id="mobile-nav" data-mobile-nav aria-label="Mobile menu" role="dialog" aria-modal="true">
        <div class="mobile-nav__header">
            <div class="logo">Bogi<span>Horvath</span></div>
            <button class="mobile-nav__close" type="button" data-nav-close aria-label="Close menu">
                <i class="fas fa-times" aria-hidden="true"></i>
            </button>
        </div>
        <div class="mobile-nav__body">
            <div class="mobile-nav__group">
                <span class="mobile-nav__group-label">Pages</span>
                <div class="mobile-nav__links">
                    {% for item in nav.pages %}
                    {% set isActive = (page.url == item.href) or (item.href != '/' and page.url and page.url.startsWith(item.href)) %}
                    <a class="mobile-nav__link{% if isActive %} is-active{% endif %}" href="{{ item.href }}"{% if isActive %} aria-current="page"{% endif %}>
                        <span class="mobile-nav__link-label">{{ item.label }}</span>
                        <i class="fas fa-arrow-right mobile-nav__link-arrow" aria-hidden="true"></i>
                    </a>
                    {% endfor %}
                </div>
            </div>

            {% if nav.sections and nav.sections.length %}
            <div class="mobile-nav__group">
                <span class="mobile-nav__group-label">On the home page</span>
                <div class="mobile-nav__links mobile-nav__links--sections">
                    {% for item in nav.sections %}
                    <a class="mobile-nav__link mobile-nav__link--section" href="{{ item.href }}">
                        <span class="mobile-nav__link-hash" aria-hidden="true">#</span>
                        <span class="mobile-nav__link-label">{{ item.label }}</span>
                    </a>
                    {% endfor %}
                </div>
            </div>
            {% endif %}

            <div class="mobile-nav__ctas">
                <a class="mobile-nav__cta mobile-nav__cta--primary" href="{{ site.contact.resume }}" target="_blank" rel="noopener noreferrer" data-cta-location="mobile_nav">
                    <i class="far fa-file-pdf" aria-hidden="true"></i>
                    Download CV — 2 pages, no signup
                </a>
                <a class="mobile-nav__cta mobile-nav__cta--secondary" href="/#contact" data-cta-location="mobile_nav_contact">
                    <i class="fas fa-envelope" aria-hidden="true"></i>
                    Send a message
                </a>
            </div>
            <div class="mobile-nav__contact">
                <a href="{{ site.contact.linkedin }}" target="_blank" rel="noopener noreferrer" data-cta-location="mobile_nav_linkedin">
                    <i class="fab fa-linkedin" aria-hidden="true"></i> See recommendations on LinkedIn
                </a>
                <a href="{{ site.contact.emailHref }}">
                    <i class="far fa-envelope" aria-hidden="true"></i> {{ site.contact.email }}
                </a>
            </div>
        </div>
    </div>
