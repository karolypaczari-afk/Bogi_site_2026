    <div class="top-bar">
        <div class="container">
            <div class="top-bar__inner">
                <div class="top-bar__contact">
                    <a href="{{ site.contact.linkedin }}" target="_blank" rel="noopener noreferrer">
                        <i class="fab fa-linkedin" aria-hidden="true"></i>
                        <span>LinkedIn</span>
                    </a>
                    <a href="{{ site.contact.emailHref }}">
                        <i class="far fa-envelope" aria-hidden="true"></i>
                        <span>{{ site.contact.email }}</span>
                    </a>
                </div>
                <div class="top-bar__actions">
                    <div class="top-bar__status">
                        <span class="pulse-dot" aria-hidden="true"></span>
                        <span>{{ site.availabilityShort }}</span>
                    </div>
                    <a class="top-bar__cta" href="{{ site.contact.resume }}" target="_blank" rel="noopener noreferrer">
                        <i class="far fa-file-alt" aria-hidden="true"></i>
                        <span>Download CV</span>
                    </a>
                </div>
            </div>
        </div>
    </div>
