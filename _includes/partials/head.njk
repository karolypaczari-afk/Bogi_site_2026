    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="theme-color" content="{{ site.themeColor }}">
    <meta name="color-scheme" content="light">
    <meta name="format-detection" content="telephone=no">
    <meta name="robots" content="{{ metaRobots or 'index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1' }}">
    <meta name="googlebot" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1">
    <meta name="bingbot" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1">
    <meta name="referrer" content="strict-origin-when-cross-origin">

    <title>{{ title or (site.name + " | " + site.title) }}</title>
    <meta name="description" content="{{ description or site.description }}">
    <meta name="keywords" content="{{ keywords or site.keywords }}">
    <meta name="author" content="{{ site.author }}">
    <meta name="publisher" content="{{ site.author }}">
    <meta name="geo.region" content="BE">
    <meta name="geo.placename" content="Belgium">

    <link rel="canonical" href="{{ canonical or site.url }}">
    <link rel="alternate" hreflang="en" href="{{ canonical or site.url }}">
    <link rel="alternate" hreflang="x-default" href="{{ canonical or site.url }}">
    <link rel="alternate" type="text/plain" title="LLM-friendly summary" href="{{ site.url }}/llms.txt">
    <link rel="alternate" type="text/plain" title="LLM-friendly full content" href="{{ site.url }}/llms-full.txt">
    <link rel="alternate" type="application/rss+xml" title="Bogi Horvath — Blog" href="{{ site.url }}/blog/feed.xml">
    <link rel="me" href="{{ site.contact.linkedin }}">
    <link rel="author" href="{{ site.url }}/about/">

    {# Open Graph #}
    <meta property="og:type" content="{{ ogType or 'website' }}">
    <meta property="og:url" content="{{ canonical or site.url }}">
    <meta property="og:title" content="{{ ogTitle or title or (site.name + ' | ' + site.title) }}">
    <meta property="og:description" content="{{ ogDescription or description or site.descriptionShort }}">
    <meta property="og:image" content="{{ ogImage or site.defaultOgImage }}">
    <meta property="og:image:width" content="{{ ogImageWidth or '1200' }}">
    <meta property="og:image:height" content="{{ ogImageHeight or '630' }}">
    <meta property="og:image:alt" content="{{ ogImageAlt or (site.fullName + ' — ' + site.title) }}">
    <meta property="og:image:type" content="image/webp">
    <meta property="og:site_name" content="{{ site.name }} Portfolio">
    <meta property="og:locale" content="en_US">
    {% if ogType == "article" and blogPost %}
    <meta property="article:published_time" content="{{ blogPost.date }}T00:00:00Z">
    <meta property="article:modified_time" content="{{ blogPost.date }}T00:00:00Z">
    <meta property="article:author" content="{{ site.url }}/about/">
    <meta property="article:section" content="{{ blogPost.category }}">
    <meta property="article:tag" content="{{ blogPost.category }}">
    {% endif %}

    {# Twitter / X #}
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="{{ ogTitle or title or (site.name + ' | ' + site.title) }}">
    <meta name="twitter:description" content="{{ ogDescription or description or site.descriptionShort }}">
    <meta name="twitter:image" content="{{ ogImage or site.defaultOgImage }}">
    <meta name="twitter:image:alt" content="{{ ogImageAlt or (site.fullName + ' — ' + site.title) }}">
    <meta name="twitter:label1" content="Written by"><meta name="twitter:data1" content="{{ site.fullName }}">
    {% if ogType == "article" and blogPost %}
    <meta name="twitter:label2" content="Filed under"><meta name="twitter:data2" content="{{ blogPost.category }}">
    {% endif %}

    {# Favicons #}
    <link rel="icon" type="image/x-icon" href="/favicon.ico">
    <link rel="icon" type="image/png" sizes="32x32" href="/img/favicon-32x32.png">
    <link rel="icon" type="image/png" sizes="192x192" href="/img/favicon-192x192.png">
    <link rel="apple-touch-icon" sizes="180x180" href="/img/apple-touch-icon.png">
    <link rel="manifest" href="/manifest.webmanifest">

    {# Preconnect + resource hints (order matters) #}
    <link rel="preconnect" href="https://www.googletagmanager.com">
    <link rel="dns-prefetch" href="https://www.google-analytics.com">
    <link rel="dns-prefetch" href="https://www.clarity.ms">
    <link rel="dns-prefetch" href="https://api.web3forms.com">

    {# Self-hosted Google Fonts + Font Awesome (previously cdnjs + fonts.googleapis.com).
       Fraunces + Inter Tight: browser auto-filters subsets via unicode-range.
       Font Awesome: full ~100 KB CSS served here; woff2 files preload below. #}
    <link rel="preload" as="font" type="font/woff2" href="/fonts/fraunces-6NUV8FyLNQOQZAnv9ZwIlOk.woff2" crossorigin>
    <link rel="preload" as="font" type="font/woff2" href="/fonts/intertight-NGSwv5HMAFg6IuGlBNMjxLsH8ag.woff2" crossorigin>
    <link rel="stylesheet" href="/fonts/fonts.css?v={{ buildHash }}">

    {# Font Awesome 6.5.1 Free — self-hosted at /fonts/fa.css + /fonts/fa-*.woff2.
       Async-loaded via media="print" onload swap so it never render-blocks. #}
    <link rel="stylesheet" href="/fonts/fa-subset.css?v={{ buildHash }}"
          media="print" onload="this.media='all'">
    <noscript>
        <link rel="stylesheet" href="/fonts/fa-subset.css?v={{ buildHash }}">
    </noscript>

    {# Main stylesheet #}
    <link rel="stylesheet" href="/css/style.css?v={{ buildHash }}">

    {% if preloadHero %}<link rel="preload" as="image" href="{{ preloadHero }}" fetchpriority="high">{% endif %}

    {# Google Consent Mode v2 — opt-out model: all granted by default, tracking-loader flips to denied only if user rejects via banner. #}
    <script>
        window.dataLayer = window.dataLayer || [];
        function gtag() { dataLayer.push(arguments); }
        gtag('consent', 'default', {
            ad_storage: 'granted',
            ad_user_data: 'granted',
            ad_personalization: 'granted',
            analytics_storage: 'granted',
            functionality_storage: 'granted',
            personalization_storage: 'granted',
            security_storage: 'granted',
            wait_for_update: 500
        });
    </script>

    {# Structured data — Person #}
    <script type="application/ld+json">
    {
        "@context": "https://schema.org",
        "@type": "Person",
        "@id": "{{ site.url }}/#person",
        "name": "{{ site.fullName }}",
        "alternateName": ["{{ site.name }}", "Bogi", "Boglarka Horvath", "Boglárka Horváth", "Boglárka Paczari-Horvath", "Paczari Horváth Boglárka"],
        "givenName": "Boglárka",
        "familyName": "Paczari-Horváth",
        "jobTitle": "{{ site.title }}",
        "url": "{{ site.url }}",
        "image": {
            "@type": "ImageObject",
            "url": "{{ site.defaultOgImage }}",
            "width": 1200,
            "height": 630
        },
        "sameAs": ["{{ site.contact.linkedin }}"],
        "description": "{{ site.descriptionShort }}",
        "knowsAbout": {{ site.knowsAbout | dump | safe }},
        "worksFor": {
            "@type": "Organization",
            "name": "S.W.I.F.T.",
            "url": "https://www.swift.com/",
            "sameAs": "https://en.wikipedia.org/wiki/SWIFT"
        },
        "alumniOf": [
            { "@type": "Organization", "name": "NTT Ltd.",        "url": "https://services.global.ntt/" },
            { "@type": "Organization", "name": "British Telecom", "url": "https://www.bt.com/",          "sameAs": "https://en.wikipedia.org/wiki/BT_Group" },
            { "@type": "Organization", "name": "T-Systems",       "url": "https://www.t-systems.com/",   "sameAs": "https://en.wikipedia.org/wiki/T-Systems" }
        ],
        "hasOccupation": {
            "@type": "Occupation",
            "name": "AI-Augmented Process Transformation Lead",
            "occupationLocation": { "@type": "Country", "name": "Belgium" },
            "occupationalCategory": "13-1111.00",
            "skills": {{ site.knowsAbout | dump | safe }},
            "experienceRequirements": "14+ years operationalising AI in regulated Tier-1 enterprises (SWIFT, NTT, BT, T-Systems). EUR 1.1M+ documented savings. Daily production user of Claude Code CLI, Model Context Protocol (MCP), ChatGPT Enterprise, Microsoft Copilot Studio, Celonis, SAP Signavio."
        },
        "seeks": {
            "@type": "Demand",
            "name": "Head of AI / Process Transformation Lead / AI-augmented BPM — remote contract or interim mandates"
        },
        "knowsLanguage": [
            { "@type": "Language", "name": "English", "alternateName": "en" },
            { "@type": "Language", "name": "Hungarian", "alternateName": "hu" },
            { "@type": "Language", "name": "German", "alternateName": "de" }
        ],
        "email": "{{ site.contact.email }}",
        "nationality": { "@type": "Country", "name": "Hungary" },
        "homeLocation": { "@type": "Country", "name": "Belgium" }
    }
    </script>

    {# Structured data — WebSite (enables sitelinks search box) #}
    <script type="application/ld+json">
    {
        "@context": "https://schema.org",
        "@type": "WebSite",
        "@id": "{{ site.url }}/#website",
        "url": "{{ site.url }}",
        "name": "{{ site.name }} | AI-Augmented Process Transformation Lead",
        "description": "{{ site.descriptionShort }}",
        "publisher": { "@id": "{{ site.url }}/#person" },
        "inLanguage": "en-US"
    }
    </script>

    {# Structured data — WebPage #}
    <script type="application/ld+json">
    {
        "@context": "https://schema.org",
        "@type": "WebPage",
        "@id": "{{ canonical or site.url }}#webpage",
        "url": "{{ canonical or site.url }}",
        "name": "{{ title or (site.name + ' | ' + site.title) }}",
        "description": "{{ description or site.descriptionShort }}",
        "isPartOf": { "@id": "{{ site.url }}/#website" },
        "primaryImageOfPage": { "@type": "ImageObject", "url": "{{ ogImage or site.defaultOgImage }}" },
        "inLanguage": "en-US",
        "author": { "@id": "{{ site.url }}/#person" },
        "speakable": {
            "@type": "SpeakableSpecification",
            "cssSelector": ["h1", ".section-lead", ".hero__subhead", ".post__summary-text"]
        }
    }
    </script>

    {% if pageType == "home" %}
    {# ProfessionalService + service catalog #}
    <script type="application/ld+json">
    {
        "@context": "https://schema.org",
        "@type": "ProfessionalService",
        "@id": "{{ site.url }}/#service",
        "name": "{{ site.name }} — AI-Augmented Process Transformation Consulting",
        "provider": { "@id": "{{ site.url }}/#person" },
        "url": "{{ site.url }}",
        "image": "{{ site.defaultOgImage }}",
        "description": "AI-augmented process transformation, production AI tooling (Claude Code CLI + MCP, ChatGPT Enterprise, Microsoft Copilot Studio), process mining (Celonis, SAP Signavio), SAP S/4HANA and PEGA consulting, Lean Six Sigma programs, and EU AI Act governance for regulated Tier-1 financial services and telecom enterprises.",
        "areaServed": { "@type": "Place", "name": "Global (remote — EU/UK primary, US Eastern compatible)" },
        "serviceType": ["AI-Augmented Process Transformation", "Head of AI Mandates", "AI Governance & EU AI Act Readiness", "Process Mining", "Business Analysis", "Digital Transformation", "Process Optimization", "Change Management"],
        "priceRange": "$$$",
        "availableLanguage": ["English", "Hungarian", "German"],
        "hasOfferCatalog": {
            "@type": "OfferCatalog",
            "name": "AI-Augmented Transformation Services",
            "itemListElement": [
                {% for svc in services.items %}
                { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "{{ svc.title }}", "description": "{{ svc.desc }}" } }{% if not loop.last %},{% endif %}
                {% endfor %}
            ]
        }
    }
    </script>

    {# FAQPage schema — feeds Google rich results + LLM-friendly Q&A indexing #}
    <script type="application/ld+json">
    {
        "@context": "https://schema.org",
        "@type": "FAQPage",
        "@id": "{{ site.url }}/#faq",
        "mainEntity": [
            {
                "@type": "Question",
                "name": "What roles is Boglarka Paczari-Horvath available for?",
                "acceptedAnswer": {
                    "@type": "Answer",
                    "text": "Booking next remote contract and interim mandate at Head of AI, Process Transformation Lead, AI-augmented BPM, or Senior Business Analyst / Team Lead level. EU/UK primary, US Eastern Time compatible. B2B via InnovateIT Kft (Hungary), or perm if structurable as B2B."
                }
            },
            {
                "@type": "Question",
                "name": "What AI tools does she use in production daily?",
                "acceptedAnswer": {
                    "@type": "Answer",
                    "text": "Claude Code CLI, Anthropic SDK, Model Context Protocol (MCP) servers (Tavily, Context7, GitHub), ChatGPT Enterprise, Claude Projects, Microsoft Copilot Studio, Google Antigravity, n8n workflow orchestration, plus Celonis EMS and SAP Signavio for process mining."
                }
            },
            {
                "@type": "Question",
                "name": "What documented business impact has she delivered?",
                "acceptedAnswer": {
                    "@type": "Answer",
                    "text": "EUR 1.1M+ in documented cost savings across 14+ years at SWIFT, NTT, BT, T-Systems. Specific anchors: EUR 500k+ license consolidation at NTT, 50% incident-volume reduction at BT, 60% documentation-time savings at SWIFT via AI-assisted source-code and API analysis, 21% PEGA workflow adoption uplift, 15+ FTE-equivalent savings via automation."
                }
            },
            {
                "@type": "Question",
                "name": "How does she handle AI governance and compliance?",
                "acceptedAnswer": {
                    "@type": "Answer",
                    "text": "EU AI Act fluent. Ships AI with audit-grade controls baked in — model risk lineage, transparency obligations, conformity assessment. ISO/IEC 42001-aware. Six Sigma + ITIL governance fluency translates directly into AI risk management for regulated enterprises."
                }
            },
            {
                "@type": "Question",
                "name": "What sectors and clients has she worked with?",
                "acceptedAnswer": {
                    "@type": "Answer",
                    "text": "14+ years inside Tier-1 financial services and telecom infrastructure: S.W.I.F.T. (Belgium, since 2024), NTT Ltd. (2022-2024), British Telecom (2015-2022), T-Systems (2011-2015). Sectors: Financial Services, Banking, FinTech, Telecommunications, IT Services, Enterprise Software, Regulated enterprise."
                }
            },
            {
                "@type": "Question",
                "name": "What's her response time and engagement model?",
                "acceptedAnswer": {
                    "@type": "Answer",
                    "text": "Under 24 hours response time. Single-engagement model — total commitment to one transformation at a time, 12-18 month deep mandates. B2B via InnovateIT Kft (Hungary), or perm if structurable. EU citizen, no visa sponsorship needed."
                }
            }
        ]
    }
    </script>
    {% endif %}

    {% if breadcrumbs %}
    <script type="application/ld+json">
    {
        "@context": "https://schema.org",
        "@type": "BreadcrumbList",
        "@id": "{{ canonical }}#breadcrumb",
        "itemListElement": [
            {% for crumb in breadcrumbs %}
            { "@type": "ListItem", "position": {{ loop.index }}, "name": "{{ crumb.name }}", "item": "{{ crumb.url }}" }{% if not loop.last %},{% endif %}
            {% endfor %}
        ]
    }
    </script>
    {% endif %}

    {% if ogType == "article" and blogPost %}
    {# Full BlogPosting schema #}
    <script type="application/ld+json">
    {
        "@context": "https://schema.org",
        "@type": "BlogPosting",
        "@id": "{{ canonical }}#article",
        "headline": {{ blogPost.title | dump | safe }},
        "alternativeHeadline": {{ blogPost.title | dump | safe }},
        "description": {{ blogPost.summary | dump | safe }},
        "datePublished": "{{ blogPost.date }}",
        "dateModified": "{{ blogPost.date }}",
        "author": { "@id": "{{ site.url }}/#person" },
        "publisher": {
            "@type": "Person",
            "name": "{{ site.fullName }}",
            "url": "{{ site.url }}",
            "logo": { "@type": "ImageObject", "url": "{{ site.defaultOgImage }}" }
        },
        "mainEntityOfPage": { "@id": "{{ canonical }}#webpage" },
        "articleSection": "{{ blogPost.category }}",
        "inLanguage": "en-US",
        "keywords": "{{ blogPost.category }}, AI-Augmented Process Transformation, Process Optimization, Digital Transformation, Lean Six Sigma, Business Analysis, Head of AI, EU AI Act, Process Mining, Claude Code, Model Context Protocol",
        "image": {
            "@type": "ImageObject",
            "url": "{{ site.url }}{{ blogPost.cover }}",
            "width": 1200,
            "height": 675
        },
        "isPartOf": { "@id": "{{ site.url }}/#website" }
    }
    </script>
    {% endif %}
