{# Post-download success modal — fires ~1.5s after any CV download click.
   Chains primary conversion (CV) → secondary (LinkedIn) / tertiary (message). #}
<div class="post-dl" data-post-dl hidden aria-hidden="true" role="dialog" aria-modal="true" aria-labelledby="post-dl-title">
    <div class="post-dl__backdrop" data-post-dl-close aria-hidden="true"></div>
    <div class="post-dl__panel">
        <button class="post-dl__close" type="button" data-post-dl-close aria-label="Close">
            <i class="fas fa-times" aria-hidden="true"></i>
        </button>
        <div class="post-dl__check" aria-hidden="true"><i class="fas fa-check"></i></div>
        <h3 class="post-dl__title" id="post-dl-title">CV downloaded.</h3>
        <p class="post-dl__sub">Want to talk? I reply in under 24 hours.</p>
        <div class="post-dl__actions">
            <a class="btn btn--linkedin"
               href="{{ site.contact.linkedin }}"
               target="_blank"
               rel="noopener noreferrer"
               data-cta-location="post_download_modal"
               data-post-dl-linkedin>
                <i class="fab fa-linkedin" aria-hidden="true"></i>
                Message me on LinkedIn
            </a>
            <a class="btn btn--secondary"
               href="/#contact"
               data-cta-location="post_download_modal_message"
               data-post-dl-message>
                <i class="far fa-envelope" aria-hidden="true"></i>
                Send a message
            </a>
        </div>
    </div>
</div>
