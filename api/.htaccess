# Protect API directory — only the .php endpoints are reachable
<FilesMatch "\.(log|txt|jsonl|json|md)$">
    Require all denied
</FilesMatch>

# Block the submissions + rate + events dirs entirely
RewriteEngine On
RewriteRule ^(submissions|rate|events)(/.*)?$ - [F,L]

# Block directory indexing
Options -Indexes
