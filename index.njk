---
layout: "base.njk"
title: "Bogi Horvath — Senior Business Analyst & Transformation Lead"
ogTitle: "Bogi Horvath | Senior BA & Digital Transformation Lead | SAP, PEGA, AI"
canonical: "https://bogihorvath.com/"
preloadHero: "/img/bogi-horvath-portrait.webp"
pageType: "home"
ogImageAlt: "Boglárka Paczari-Horvath — Senior Business Analyst & Digital Transformation Lead"
---
{% set h = hero %}
{% set f = features %}
{% set s = services %}
{% set k = skills %}
{% set a = achievements %}
{% set tl = timeline %}
{% set t = testimonials %}
{% set c = certs %}
{% set co = contact %}

{# ============================================================
   HERO — proof-first, CV-primary
   ============================================================ #}
<section class="hero">
    <div class="hero-blob hero-blob--1" aria-hidden="true"></div>
    <div class="hero-blob hero-blob--2" aria-hidden="true"></div>
    <div class="container">
        <div class="hero__grid">
            <div class="hero__content">
                <div class="hero__availability reveal">
                    <span class="pulse-dot" aria-hidden="true"></span>
                    <span>{{ site.availability }}</span>
                </div>

                <h1 class="hero__headline reveal">
                    <span class="hero-line" style="--line:0"><span>{{ h.headingLead }}</span></span>
                    <span class="hero-line hero-line--accent" style="--line:1"><span><em>{{ h.headingAccent }}</em></span></span>
                    <span class="hero-line hero-line--tail" style="--line:2"><span>{{ h.headingTail }}</span></span>
                </h1>

                <p class="hero__subhead reveal">{{ h.subhead | safe }}</p>

                <div class="hero__clients hero__clients--inline reveal">
                    <span class="hero__clients-label">Proven at</span>
                    <div class="hero__clients-row">
                        {% for client in h.clients %}
                        <span class="hero__client">{{ client }}</span>
                        {% endfor %}
                    </div>
                </div>

                <div class="hero__ctas reveal">
                    <a class="btn btn--primary hero__cta-primary"
                       href="{{ site.contact.resume }}"
                       target="_blank"
                       rel="noopener noreferrer"
                       data-cta-location="hero_primary">
                        <i class="far fa-file-pdf" aria-hidden="true"></i>
                        <span class="hero__cta-primary-text">
                            <span class="hero__cta-primary-label">{{ h.primaryCta.label }}</span>
                            <span class="hero__cta-primary-sub">{{ h.primaryCta.sub }}</span>
                        </span>
                    </a>
                    <a class="btn btn--secondary"
                       href="{{ site.contact.linkedin }}"
                       target="_blank"
                       rel="noopener noreferrer"
                       data-cta-location="hero_secondary">
                        <i class="fab fa-linkedin" aria-hidden="true"></i>
                        {{ h.secondaryCta.label }}
                    </a>
                </div>

                <details class="hero__value-stack reveal">
                    <summary class="hero__value-stack-summary">
                        <i class="fas fa-list-check" aria-hidden="true"></i>
                        What's in the 2-page CV
                        <i class="fas fa-chevron-down hero__value-stack-chevron" aria-hidden="true"></i>
                    </summary>
                    <ul class="hero__value-stack-list">
                        {% for item in h.valueStack.items %}
                        <li>{{ item }}</li>
                        {% endfor %}
                    </ul>
                </details>
            </div>

            <div class="hero__portrait-wrap reveal reveal--scale">
                <div class="hero__portrait-frame" aria-hidden="true"></div>
                <div class="hero__portrait">
                    <img src="{{ h.portraitSrc }}" alt="{{ h.portraitAlt }}" width="440" height="500" loading="eager" fetchpriority="high">
                </div>
                <div class="hero__portrait-badge">
                    <div class="hero__portrait-badge__icon"><i class="fas fa-check-circle" aria-hidden="true"></i></div>
                    <div>
                        <div class="hero__portrait-badge__value">{{ h.floatingBadge.value }}</div>
                        <div class="hero__portrait-badge__label">{{ h.floatingBadge.label }}</div>
                    </div>
                </div>
            </div>
        </div>

        <div class="hero__stats" data-stagger>
            {% for stat in h.stats %}
            <div class="stat-card reveal">
                <div class="stat-card__icon"><i class="fas {{ stat.icon }}" aria-hidden="true"></i></div>
                <span class="stat-card__value" data-countup data-final="{{ stat.value }}">{{ stat.value }}</span>
                <div class="stat-card__label">{{ stat.label }}</div>
                <div class="stat-card__sub">{{ stat.subLabel }}</div>
            </div>
            {% endfor %}
        </div>
    </div>
</section>

{# ============================================================
   FOR RECRUITERS — 10-second scan card
   ============================================================ #}
{% include "partials/for-recruiters-card.njk" %}

{# ============================================================
   ACHIEVEMENTS — moved up, hard metrics second
   ============================================================ #}
<section class="achievements" id="achievements">
    <div class="achievements__blob" aria-hidden="true"></div>
    <div class="container">
        <div class="section-header reveal">
            <span class="eyebrow">{{ a.eyebrow }}</span>
            <h2 class="section-title">{{ a.heading }}</h2>
            <p class="section-lead">{{ a.subhead }}</p>
        </div>
        <div class="achievements__grid" data-stagger>
            {% for item in a.items %}
            <article class="achievement-card reveal">
                <div class="achievement-card__icon"><i class="fas {{ item.icon }}" aria-hidden="true"></i></div>
                <h3 class="achievement-card__title">{{ item.title }}</h3>
                <p class="achievement-card__desc">{{ item.desc }}</p>
            </article>
            {% endfor %}
        </div>
    </div>
</section>

{# ---- Inline CTA #1 — after Achievements ---- #}
{% set inlineCtaLocation = "inline_after_achievements" %}
{% set inlineCtaHeading = "Seen the numbers. Want the details?" %}
{% set inlineCtaSub = "Every € and % above is sourced to a specific project, client, and year in the CV." %}
{% include "partials/inline-cv-cta.njk" %}

{# ============================================================
   TESTIMONIALS — moved up, social proof after metrics
   ============================================================ #}
<section class="testimonials" id="references">
    <div class="container">
        <div class="section-header reveal">
            <span class="eyebrow">{{ t.eyebrow }}</span>
            <h2 class="section-title">{{ t.heading | safe }}</h2>
            <p class="section-lead">{{ t.subhead }}</p>
        </div>
        <div class="testimonials__grid" data-stagger>
            {% for item in t.items %}
            <article class="testimonial-card reveal" data-testimonial data-expanded="false">
                <span class="testimonial-card__quote" aria-hidden="true">&ldquo;</span>
                <p class="testimonial-card__text" data-testimonial-text data-summary="{{ item.summary | escape }}" data-full="{{ item.fullReview | escape }}">{{ item.summary }}</p>
                <button class="testimonial-card__toggle" type="button" data-testimonial-toggle aria-label="Toggle full review">
                    <i class="fas fa-chevron-down" aria-hidden="true"></i>
                    <i class="fas fa-chevron-up" aria-hidden="true"></i>
                    <span class="label-more">Read Full Review</span>
                    <span class="label-less">Show Less</span>
                </button>
                <footer class="testimonial-card__footer">
                    <div class="testimonial-card__avatar">
                        <img src="{{ item.image }}" alt="{{ item.author }}" width="56" height="56" loading="lazy">
                    </div>
                    <div>
                        <h4 class="testimonial-card__author">{{ item.author }}</h4>
                        <p class="testimonial-card__role">{{ item.role }}</p>
                        <p class="testimonial-card__company">{{ item.company }}</p>
                        <p class="testimonial-card__relationship">{{ item.relationship }}</p>
                    </div>
                </footer>
            </article>
            {% endfor %}
        </div>
        <div class="testimonials__cta reveal">
            <a class="btn btn--linkedin" href="{{ site.contact.linkedin }}" target="_blank" rel="noopener noreferrer" data-cta-location="testimonials_linkedin">
                <i class="fab fa-linkedin" aria-hidden="true"></i>
                See all 15+ recommendations on LinkedIn
            </a>
        </div>
    </div>
</section>

{# ---- Inline CTA #2 — after Testimonials ---- #}
{% set inlineCtaLocation = "inline_after_testimonials" %}
{% set inlineCtaHeading = "Convinced? Skip the recruiter chain." %}
{% set inlineCtaSub = "One tap, 2 pages, no signup. Direct contact details inside the PDF." %}
{% include "partials/inline-cv-cta.njk" %}

{# ============================================================
   TIMELINE — kept, not moved up
   ============================================================ #}
<section class="timeline" id="experience">
    <div class="container">
        <div class="section-header reveal">
            <span class="eyebrow">{{ tl.eyebrow }}</span>
            <h2 class="section-title">{{ tl.heading }}</h2>
            <p class="section-lead">{{ tl.subhead }}</p>
        </div>
        <ol class="timeline__list">
            {% for event in tl.events %}
            <li class="timeline__item reveal reveal--right">
                <article class="timeline-card">
                    <div class="timeline-card__row">
                        <div class="timeline-card__logo timeline-card__logo--{{ event.logoColor }}">{{ event.logo }}</div>
                        <div>
                            <span class="timeline-card__date">{{ event.date }}</span>
                            <h3 class="timeline-card__title">{{ event.title }}</h3>
                            <div class="timeline-card__company">{{ event.company }}</div>
                            <p class="timeline-card__desc">{{ event.desc }}</p>
                            {% if event.highlights %}
                            <div class="timeline-card__highlights">
                                {% for highlight in event.highlights %}
                                <span class="highlight-pill">{{ highlight }}</span>
                                {% endfor %}
                            </div>
                            {% endif %}
                        </div>
                    </div>
                </article>
            </li>
            {% endfor %}
        </ol>
    </div>
</section>

{# ============================================================
   HOW I WORK — compressed to 4 outcome cards (was "features")
   ============================================================ #}
<section class="features" id="how">
    <div class="container">
        <div class="section-header reveal">
            <span class="eyebrow">{{ f.eyebrow }}</span>
            <h2 class="section-title">{{ f.heading | safe }}</h2>
            <p class="section-lead">{{ f.subhead }}</p>
        </div>

        <div class="features__grid" data-stagger>
            {% for card in f.approach %}
            <article class="approach-card reveal">
                <div class="approach-card__icon"><i class="fas {{ card.icon }}" aria-hidden="true"></i></div>
                <h3 class="approach-card__title">{{ card.title }}</h3>
                <p class="approach-card__desc">{{ card.desc }}</p>
                {% if card.aiTools %}
                <div class="approach-card__ai-tools" aria-label="AI tools">
                    <span class="ai-tool ai-tool--chatgpt" title="ChatGPT">CG</span>
                    <span class="ai-tool ai-tool--copilot" title="Microsoft Copilot"><i class="fab fa-microsoft" aria-hidden="true"></i></span>
                    <span class="ai-tool ai-tool--claude" title="Claude">C</span>
                    <span class="ai-tool ai-tool--gemini" title="Gemini">G</span>
                </div>
                {% endif %}
            </article>
            {% endfor %}
        </div>
    </div>
</section>

{# ============================================================
   SERVICES — compressed to 4 delivery categories
   ============================================================ #}
<section class="services" id="services">
    <div class="container">
        <div class="section-header reveal">
            <span class="eyebrow">{{ s.eyebrow }}</span>
            <h2 class="section-title">{{ s.heading | safe }}</h2>
            <p class="section-lead">{{ s.subhead }}</p>
        </div>
        <div class="services__grid" data-stagger>
            {% for svc in s.items %}
            <article class="service-card reveal">
                <span class="service-card__num">{{ svc.num }}</span>
                <h3 class="service-card__title">{{ svc.title }}</h3>
                <p class="service-card__desc">{{ svc.desc }}</p>
            </article>
            {% endfor %}
        </div>
    </div>
</section>

{# ---- Inline CTA #3 — after Services ---- #}
{% set inlineCtaLocation = "inline_after_services" %}
{% set inlineCtaHeading = "Need this playbook for your org?" %}
{% set inlineCtaSub = "Full experience, stack, and engagement options in the 2-page CV." %}
{% include "partials/inline-cv-cta.njk" %}

{# ============================================================
   SKILLS — compressed to single-row tech stack
   ============================================================ #}
<section class="skills skills--compact" id="skills">
    <div class="container">
        <div class="section-header reveal">
            <span class="eyebrow">{{ k.eyebrow }}</span>
            <h2 class="section-title">{{ k.heading | safe }}</h2>
        </div>
        <div class="skills-strip reveal" data-stagger>
            {% for cat in k.categories %}
            <div class="skills-strip__row">
                <div class="skills-strip__head">
                    <span class="skills-strip__icon skills-strip__icon--{{ cat.color }}">
                        <i class="fas {{ cat.icon }}" aria-hidden="true"></i>
                    </span>
                    <span class="skills-strip__title">{{ cat.title }}</span>
                </div>
                <div class="skills-strip__tags">
                    {% for skill in cat.skills %}
                    <span class="skill-tag {% if skill.highlight %}skill-tag--highlight{% endif %}">{{ skill.name }}</span>
                    {% endfor %}
                </div>
            </div>
            {% endfor %}
        </div>
    </div>
</section>

{# ============================================================
   CERTIFICATIONS — compressed to pill list
   ============================================================ #}
<section class="certs certs--compact" id="certifications">
    <div class="container">
        <div class="section-header reveal">
            <span class="eyebrow">{{ c.eyebrow }}</span>
            <h2 class="section-title">{{ c.heading }}</h2>
        </div>
        <div class="certs-pills reveal">
            {% for cat in c.categories %}
                {% for cert in cat.certs %}
                <span class="cert-pill">
                    <i class="fas {{ cert.icon }} cert-pill__icon cert-pill__icon--{{ cert.color }}" aria-hidden="true"></i>
                    <span class="cert-pill__name">{{ cert.name }}</span>
                    <span class="cert-pill__org">{{ cert.org }}</span>
                </span>
                {% endfor %}
            {% endfor %}
        </div>
    </div>
</section>

{# ============================================================
   CONTACT — last section, form tertiary
   ============================================================ #}
<section class="contact" id="contact">
    <div class="container">
        <div class="contact__card reveal">
            <div class="contact__blob contact__blob--1" aria-hidden="true"></div>
            <div class="contact__blob contact__blob--2" aria-hidden="true"></div>
            <div class="contact__grid">
                <div class="contact__left">
                    <span class="eyebrow">{{ co.eyebrow }}</span>
                    <h2 class="contact__heading">{{ co.heading | safe }}</h2>
                    <p class="contact__lead">{{ co.subhead }}</p>
                    <div class="contact__channels">
                        {% for ch in co.channels %}
                        <a class="contact__channel"
                           href="{{ ch.href }}"
                           {% if ch.href | first == 'h' %} target="_blank" rel="noopener noreferrer"{% endif %}
                           data-cta-location="contact_channels">
                            <span class="contact__channel-icon"><i class="{{ ch.icon }}" aria-hidden="true"></i></span>
                            <span class="contact__channel-text">{{ ch.label }}</span>
                        </a>
                        {% endfor %}
                    </div>
                </div>

                <div class="contact__form-card">
                    <h3 class="contact__form-title">{{ co.formTitle }}</h3>
                    <p class="contact__form-subhead">{{ co.formSubhead }}</p>

                    <form class="form"
                          data-contact-form
                          data-access-key="{{ site.forms.web3formsAccessKey }}"
                          data-cc="{{ site.forms.ccRecipients }}"
                          data-from-name="Bogi Horvath Website"
                          data-subject="New Contact Message from website"
                          novalidate>
                        <input type="text" name="botcheck" class="form__honey" tabindex="-1" autocomplete="off">
                        <input type="hidden" name="source" value="contact_form">

                        <div class="form__row">
                            <label class="form__label" for="contact-name">Full Name</label>
                            <input class="form__input" id="contact-name" name="name" type="text" required placeholder="John Doe">
                        </div>
                        <div class="form__row">
                            <label class="form__label" for="contact-email">Email Address</label>
                            <input class="form__input" id="contact-email" name="email" type="email" required placeholder="john@example.com">
                        </div>
                        <div class="form__row">
                            <label class="form__label" for="contact-message">Your Message</label>
                            <textarea class="form__textarea" id="contact-message" name="message" rows="4" required placeholder="Role / brief / question"></textarea>
                        </div>

                        <button class="form__submit" type="submit">
                            <span>Send Message</span>
                            <i class="fas fa-paper-plane" aria-hidden="true"></i>
                        </button>
                        <p class="form__note">{{ co.formFooter }}</p>
                    </form>

                    <div class="form__success" data-contact-success hidden>
                        <div class="form__success-icon"><i class="fas fa-check" aria-hidden="true"></i></div>
                        <h3 class="form__success-title">{{ co.successTitle }}</h3>
                        <p class="form__success-text">{{ co.successMessage }}</p>
                        <button class="form__success-again" type="button" data-contact-reset>Send another message</button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
