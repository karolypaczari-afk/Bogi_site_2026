# ============================================
# bogihorvath.com — Performance, caching & security
# ============================================

# --- Custom 404 page ---
ErrorDocument 404 /404.html

# --- HTTPS canonical + trailing-slash normalisation ---
<IfModule mod_rewrite.c>
  RewriteEngine On

  # Redirect www → apex (or flip both lines if you prefer www canonical)
  RewriteCond %{HTTP_HOST} ^www\.bogihorvath\.com$ [NC]
  RewriteRule ^(.*)$ https://bogihorvath.com/$1 [R=301,L]

  # Force HTTPS
  RewriteCond %{HTTPS} off
  RewriteCond %{HTTP:X-Forwarded-Proto} !https
  RewriteRule ^(.*)$ https://%{HTTP_HOST}/$1 [R=301,L]

  # Add trailing slash to directory-style URLs so /about becomes /about/
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteCond %{REQUEST_URI} !(\.[a-zA-Z0-9]+|/)$
  RewriteRule ^(.*)$ /$1/ [R=301,L]
</IfModule>

# --- 301 redirects: legacy WordPress + React SPA URLs → new static URLs ---
# Rescues link equity from URLs still in Google's index (confirmed via GSC).
<IfModule mod_rewrite.c>
  RewriteEngine On

  # Legacy WordPress blog slugs (confirmed in Google Search Console)
  RewriteRule ^3-steps-to-save-500k-for-your-company/?$ /blog/500k-savings/ [R=301,L]
  RewriteRule ^case-study-driving-adoption-success-how-we-increased-workflow-adoption-by-21/?$ /blog/adoption-success/ [R=301,L]
  RewriteRule ^detecting-and-preventing-money-leaks-in-your-processes/?$ /blog/money-leaks/ [R=301,L]
  RewriteRule ^my-favourite-tools-to-initiate-a-complex-process-improvement-project/?$ /blog/process-tools/ [R=301,L]
  RewriteRule ^case-study-enhancing-process-efficiency-through-automation-in-an-it-multinational-company/?$ /blog/automation-efficiency/ [R=301,L]

  # Generic case-study index page → blog
  RewriteRule ^case-study/?$ /blog/ [R=301,L]

  # Legacy WP CV uploads → the one canonical PDF (GSC shows 22% CTR on these)
  RewriteRule ^wp-content/uploads/[0-9]{4}/[0-9]{2}/Bogi-CV-.*\.pdf$ /Bogi_CV.pdf [R=301,L]
  RewriteRule ^wp-content/uploads/.*\.pdf$ /Bogi_CV.pdf [R=301,L]

  # WordPress taxonomy pages → blog
  RewriteRule ^category/(.*)$ /blog/ [R=301,L]
  RewriteRule ^tag/(.*)$ /blog/ [R=301,L]
  RewriteRule ^author/(.*)$ /about/ [R=301,L]

  # Generic WP artifacts
  RewriteRule ^wp-content/(.*)$ / [R=301,L]
  RewriteRule ^wp-includes/(.*)$ / [R=301,L]
  RewriteRule ^wp-admin/?$ / [R=301,L]
  RewriteRule ^wp-admin/(.*)$ / [R=301,L]
  RewriteRule ^wp-login\.php$ / [R=301,L]
  RewriteRule ^xmlrpc\.php$ / [R=301,L]
  RewriteRule ^feed/?$ / [R=301,L]
  RewriteRule ^comments/feed/?$ / [R=301,L]

  # React SPA hash-based routes (shouldn't ever hit server, but 301 any bots)
  RewriteRule ^about/?$ /about/ [R=301,L]
  RewriteRule ^blog/?$ /blog/ [R=301,L]

  # Admin/login/chatbot dead routes — 410 Gone so Google drops them fast.
  # These are bot-trap paths from the previous WordPress install — no legitimate visitor hits them.
  RewriteRule ^(admin|login|chat|chatbot)/?$ - [G,L]

  # NOTE: Removed the legacy WP query-string 410 Gone rule (was blocking ?p=, ?cat=, ?s= etc).
  # Modern campaign tracking (utm_*, gclid, fbclid, _ga, wbraid) was never affected, but the
  # rule could in theory 410 any legitimate bookmark/share with those params. Safer to drop it.
</IfModule>

# --- GZIP / Brotli compression ---
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html
  AddOutputFilterByType DEFLATE text/css
  AddOutputFilterByType DEFLATE text/javascript
  AddOutputFilterByType DEFLATE application/javascript
  AddOutputFilterByType DEFLATE application/json
  AddOutputFilterByType DEFLATE application/manifest+json
  AddOutputFilterByType DEFLATE image/svg+xml
  AddOutputFilterByType DEFLATE application/xml
  AddOutputFilterByType DEFLATE text/xml
  AddOutputFilterByType DEFLATE application/rss+xml
  AddOutputFilterByType DEFLATE application/atom+xml
  AddOutputFilterByType DEFLATE text/plain
</IfModule>

# --- Browser caching ---
<IfModule mod_expires.c>
  ExpiresActive On

  # HTML — short cache so deploys are visible quickly
  ExpiresByType text/html "access plus 5 minutes"

  # CSS / JS — long cache, busted by ?v= query string on each build
  ExpiresByType text/css "access plus 1 month"
  ExpiresByType text/javascript "access plus 1 month"
  ExpiresByType application/javascript "access plus 1 month"

  # Images — long cache
  ExpiresByType image/webp "access plus 1 year"
  ExpiresByType image/jpeg "access plus 1 year"
  ExpiresByType image/png "access plus 1 year"
  ExpiresByType image/gif "access plus 1 year"
  ExpiresByType image/svg+xml "access plus 1 year"
  ExpiresByType image/x-icon "access plus 1 year"

  # Fonts — long cache
  ExpiresByType font/woff2 "access plus 1 year"
  ExpiresByType font/woff "access plus 1 year"
  ExpiresByType application/font-woff2 "access plus 1 year"
  ExpiresByType application/font-woff "access plus 1 year"

  # Manifest, feeds
  ExpiresByType application/manifest+json "access plus 1 week"
  ExpiresByType application/json "access plus 1 hour"
  ExpiresByType application/atom+xml "access plus 1 hour"
  ExpiresByType application/rss+xml "access plus 1 hour"

  # Plain-text LLM files
  ExpiresByType text/plain "access plus 1 day"

  # PDFs
  ExpiresByType application/pdf "access plus 1 month"
</IfModule>

# --- Cache-Control headers ---
<IfModule mod_headers.c>
  <FilesMatch "\.(html|htm)$">
    Header set Cache-Control "public, max-age=300, must-revalidate"
  </FilesMatch>

  <FilesMatch "\.(css|js)$">
    Header set Cache-Control "public, max-age=2592000"
  </FilesMatch>

  <FilesMatch "\.(webp|jpg|jpeg|png|gif|svg|ico)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>

  <FilesMatch "\.(woff2|woff|ttf|otf|eot)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
    Header set Access-Control-Allow-Origin "*"
  </FilesMatch>

  <FilesMatch "\.webmanifest$">
    Header set Cache-Control "public, max-age=604800"
  </FilesMatch>

  <FilesMatch "service-worker\.js$">
    Header set Cache-Control "public, max-age=0, must-revalidate"
  </FilesMatch>

  <FilesMatch "\.(txt|xml)$">
    Header set Cache-Control "public, max-age=3600"
  </FilesMatch>
</IfModule>

# --- Security headers ---
<IfModule mod_headers.c>
  Header set X-Content-Type-Options "nosniff"
  Header set X-Frame-Options "SAMEORIGIN"
  Header set Referrer-Policy "strict-origin-when-cross-origin"
  Header set Permissions-Policy "camera=(), microphone=(), geolocation=(), payment=(), interest-cohort=()"
  Header set X-XSS-Protection "1; mode=block"
  Header set Strict-Transport-Security "max-age=31536000; includeSubDomains"

  # Hide server signature
  Header unset X-Powered-By
  Header unset Server
</IfModule>

# --- MIME types ---
<IfModule mod_mime.c>
  AddType application/manifest+json .webmanifest
  AddType image/webp .webp
  AddType font/woff2 .woff2
  AddType application/atom+xml .xml
  AddType text/plain .md
  AddType text/plain .txt
</IfModule>

# --- Character set ---
AddDefaultCharset UTF-8

# --- Block hidden files + sensitive configs ---
# Broad deny on all dotfiles — covers .mcp.json, .ht*, .env*, .git*, .claude*, etc.
<FilesMatch "^\.">
    Require all denied
</FilesMatch>
<FilesMatch "(package\.json|package-lock\.json|playwright\.config\.js|biome\.json|composer\.json|composer\.lock|\.mcp\.json)$">
    Require all denied
</FilesMatch>
<IfModule mod_rewrite.c>
  RewriteEngine On
  # Dev/build/test directories
  RewriteRule ^(_data|_dev|_includes|node_modules|test-results|playwright-report)(/|$) - [F,L]
  # Archived React site — defense-in-depth if ever synced to server
  RewriteRule ^_archive(/|$) - [F,L]
  # API internal directories (rate/, events/, submissions/ logs)
  RewriteRule ^api/(events|submissions|rate)(/|$) - [F,L]
</IfModule>

# --- Disable directory listing ---
Options -Indexes
